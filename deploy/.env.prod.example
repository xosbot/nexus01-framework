# Production environment for navos.online
# Copy to .env and fill in real values

# ── LLM Provider (pick one or more) ──
# GEMINI_API_KEY=
GROQ_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Ollama (optional — CX22 has no GPU, use cloud LLM instead) ──
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen3:8b

# ── Redis ──
REDIS_URL=redis://redis:6379
BUS_BACKEND=redis

# ── API Auth ──
NEXUS_API_KEY=6VAr-gwd0DIvQmGDh__pmduSCFGtBM6bWmLhOwX877g

# ── CORS ──
NEXUS_ALLOWED_ORIGINS=https://navos.space,https://navos.online,http://localhost:8765

# ── Storage ──
DATABASE_PATH=/app/data/nexus.db
CHROMA_PATH=/app/data/chromadb

# ── Features ──
COLD_MODE_ENABLED=true
REQUIRE_APPROVAL_FOR_EXEC=true
ENABLE_CLI=false
ENABLE_WEB_UI=true
LOG_LEVEL=INFO
